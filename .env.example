# Copy this file to `.env` in the same folder as manage.py and fill in real values.
# `.env` is gitignored — never commit your actual secret key or production settings.

# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-real-random-secret-key

# True for local development only. Must be False in production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames the server will accept requests for.
# Required (non-empty) once DJANGO_DEBUG=False.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2

# Comma-separated list of exact origins allowed to call the API via CORS.
# Only used when DJANGO_DEBUG=False (DEBUG mode allows all origins for Expo Go convenience).
DJANGO_CORS_ALLOWED_ORIGINS=https://your-app-domain.example.com

# Whether to force-redirect HTTP -> HTTPS. Only applied when DJANGO_DEBUG=False.
DJANGO_SECURE_SSL_REDIRECT=True
